#include <iostream>
using namespace std;

int main() {
    int n;

    cout << "Enter number of vertices: ";
    cin >> n;

    int matrix[20][20];

    cout << "Enter adjacency matrix:\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cin >> matrix[i][j];
        }
    }

    bool isComplete = true;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (i == j) {
                if (matrix[i][j] != 0) {
                    isComplete = false;
                    break;
                }
            } else {
                if (matrix[i][j] != 1) {
                    isComplete = false;
                    break;
                }
            }
        }
        if (!isComplete)
            break;
    }

    if (isComplete)
        cout << "Graph is a Complete Graph\n";
    else
        cout << "Graph is NOT a Complete Graph\n";

    return 0;
}
