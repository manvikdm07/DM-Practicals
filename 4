#include <iostream>
#include <vector>
using namespace std;

// Function to print one solution
void printSolution(const vector<int>& x) {
    for (int i = 0; i < x.size(); i++) {
        cout << x[i];
        if (i != x.size() - 1)
            cout << " + ";
    }
    cout << endl;
}

// Brute force recursive function
void findSolutions(int n, int C, vector<int>& x, int index) {
    // If we are at last variable
    if (index == n - 1) {
        x[index] = C;   // assign remaining sum
        printSolution(x);
        return;
    }

    // Try all possible values from 0 to C
    for (int i = 0; i <= C; i++) {
        x[index] = i;
        findSolutions(n, C - i, x, index + 1);
    }
}

int main() {
    int n, C;

    cout << "Enter number of variables (n): ";
    cin >> n;

    cout << "Enter value of C (<=10): ";
    cin >> C;

    vector<int> x(n);

    cout << "\nAll solutions:\n";
    findSolutions(n, C, x, 0);

    return 0;
}
